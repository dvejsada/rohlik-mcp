# Rohlik MCP server configuration.
# Copy this file to `.env` and fill in your Rohlik.cz credentials:
#   cp .env.example .env

# --- Required ---
ROHLIK_USERNAME=your_email@example.com
ROHLIK_PASSWORD=your_password

# --- Optional (defaults shown) ---
# API base URL
#ROHLIK_BASE_URL=https://www.rohlik.cz
# Request timeout, in seconds
#ROHLIK_TIMEOUT=30
# HTTP bind host
#ROHLIK_MCP_HOST=0.0.0.0
# HTTP bind port (also the published container port in docker-compose)
#ROHLIK_MCP_PORT=8000
# HTTP endpoint path
#ROHLIK_MCP_PATH=/mcp/
